{
  "name": "zhihu-radar",
  "version": "0.0.1",
  "private": true,
  "description": "CLI tool that scans 知乎 study-abroad topics for conversion-signal density.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "pnpm run typecheck && pnpm run lint && pnpm run depcruise",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "depcruise": "depcruise src tests --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "dev": "tsx src/runtime/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
